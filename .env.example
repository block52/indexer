# Poker Hand Indexer Configuration
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker_indexer_dev
POSTGRES_DB=poker_hands
DB_HOST=postgres
DB_PORT=5432

# Node RPC endpoint
NODE_RPC=http://node1.block52.xyz:26657

# Starting block height (default: 1)
START_BLOCK=1

# Loop delay in seconds between indexing runs (default: 60)
LOOP_DELAY=60
